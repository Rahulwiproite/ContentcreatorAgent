# Copy to .env and fill in real values. DO NOT commit .env.

# === AI provider (Gemini = free tier) ===
AI_PROVIDER=gemini
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE
GEMINI_MODEL_IDEATION=gemini-2.5-flash
GEMINI_MODEL_FAST=gemini-2.5-flash

# Optional Claude fallback
ANTHROPIC_API_KEY=
CLAUDE_MODEL_IDEATION=claude-3-5-sonnet-latest
CLAUDE_MODEL_FAST=claude-3-5-haiku-latest

# === Optional live trend sources ===
# X (Twitter) API v2 Bearer Token. Free tier OK. Leave empty to skip X.
X_BEARER_TOKEN=

# Reddit RSS works without any auth -- no key needed.

# === App ===
DATABASE_URL=sqlite:///./agent.db
SECRET_KEY=change-me-to-a-random-string
TOKEN_ENCRYPTION_KEY=generate-via-python-cryptography-Fernet
CORS_ORIGINS=http://localhost:5173
